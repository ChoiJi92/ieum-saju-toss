# 이음사주 토스 미니앱 — 환경 변수 (rsbuild + import.meta.env 통해 노출)
# 실제 값은 .env (gitignore) 또는 .env.local 에 작성
#
# rsbuild 규칙: VITE_ 또는 PUBLIC_ prefix 가 붙어야 client 번들에 노출됨.

# AdMob 광고 그룹 ID (앱인토스 콘솔 → 미니앱 → 광고 → 발급)
# 출시 직전 발급받아 .env 에 작성. 미설정 시 fallback 으로 광고 없이 결과 표시.
VITE_AD_GROUP_ID=TEST_AD_GROUP

# 사주 계산 백엔드 API base URL (Phase D 본격 구현 시)
# 로컬: http://localhost:8000
# 운영: https://api.ieum-saju.example.com (또는 Vercel/Railway 도메인)
VITE_SAJU_API_BASE=http://localhost:8000
