# 이음사주 백엔드 — 토스 OAuth2 인증 환경 변수.
# 로컬 개발: 이 파일을 `.env` 또는 `.env.local`로 복사 후 채우기.
# Vercel 배포: Vercel 대시보드 → Project Settings → Environment Variables 에 등록.

# ─── 앱인토스 콘솔 → mTLS 인증서 발급 후 PEM 전체 붙여넣기 ───
# Vercel 대시보드에서 등록 시 멀티라인 PEM 전체 (BEGIN…END 포함) 그대로 붙여넣어야 함.
# 앱인토스 토스 로그인은 mTLS 자체가 파트너 인증이라 client_id/secret 불필요.
TOSS_MTLS_CERT=
TOSS_MTLS_KEY=

# (선택) Token / UserInfo URL — 발급 메일에 다른 URL 안내되면 덮어쓰기
# 기본값:
#   TOSS_TOKEN_URL=https://oauth2.cert.toss.im/oauth2/token
#   TOSS_USERINFO_URL=https://oauth2.cert.toss.im/userinfo
TOSS_TOKEN_URL=
TOSS_USERINFO_URL=

# (선택) CORS 허용 origin. 미설정 시 * (개발용)
# 운영: 토스 미니앱이 서빙되는 도메인 또는 *.apps.tossmini.com 같은 패턴
ALLOWED_ORIGIN=

# (선택) 연결 끊기 콜백 Basic Auth 헤더 — 토스 콘솔에 동일 값 등록
# 예: "Basic <base64(user:pass)>"
DISCONNECT_BASIC_AUTH=
